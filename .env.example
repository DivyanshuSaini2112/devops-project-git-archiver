# ============================================================
# Git Repository Archiver — Environment Configuration
# ============================================================
# Copy this file to src/config/.env and fill in real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# --- GitHub API ---
API_KEY=ghp_your_github_personal_access_token_here
TARGET_ORG=your-github-org-name

# --- Archiving behaviour ---
# Repos with no commits in the last STALE_DAYS days are considered stale.
STALE_DAYS=90

# --- Storage ---
# Absolute or relative path where final archives are stored.
STORAGE_DIR=/app/archives

# --- Archive format: tar.gz | zip ---
ARCHIVE_FORMAT=tar.gz

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Optional: write structured JSON logs to a file (leave empty for stdout)
LOG_FILE=

# --- Dry run (no archives written, no clones performed) ---
DRY_RUN=false

# --- GitLab (optional) ---
# GITLAB_TOKEN=glpat_your_gitlab_token
# GITLAB_URL=https://gitlab.com
